<configuration>
    <springProperty scope="context" name="LOG_LEVEL" source="logging.level.root" defaultValue="DEBUG"/>
    <appender name="STDOUT" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss} %-5level %logger{36} - %msg%n</pattern>
        </encoder>
    </appender>

    <root level="${LOG_LEVEL}">
        <appender-ref ref="STDOUT"/>
    </root>

    <!-- Configuración específica para tu clase o paquete -->
    <logger name="org.slf4j.Logger" level="DEBUG" additivity="false">
        <appender-ref ref="OFF"/>
    </logger>
</configuration>